# Universal LLM Settings (litellm compatible)
# -------------------------------------------
# LLM_MODEL: Model identifier. 
#   Examples: ollama/qwen3.5:4b, anthropic/claude-3-5-sonnet-20240620, openai/gpt-4o
LLM_MODEL=gemini/gemini-flash-latest

# LLM_API_KEY: API key for the provider (if required)
LLM_API_KEY=

# LLM_BASE_URL: Custom endpoint (e.g. for Ollama or Local API)
# LLM_BASE_URL=http://localhost:11434

# LLM_RPM_LIMIT: Request per minute limit (default: 15)
LLM_RPM_LIMIT=15

# LLM_TIMEOUT: Timeout in seconds for LLM calls (default: 600.0)
LLM_TIMEOUT=600.0

# Legacy / Provider Specific Settings
# -------------------------------------------
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest
# Docker Output Ownership Settings
# -------------------------------------------
# UID and GID to use for running the container.
# This prevents output files from being owned by root.
# On Linux, run `id -u` and `id -g` to find your values.
UID=1000
GID=1000

# RAG Optimization Settings
# -------------------------------------------
# RAG_OUTPUT_FORMAT: RAG output format ('yaml_frontmatter', 'markdown', 'jsonl')
RAG_OUTPUT_FORMAT=yaml_frontmatter

# RAG_MAX_CHUNK_CHARS: Maximum characters per chunk
RAG_MAX_CHUNK_CHARS=1000

# RAG_CHUNK_OVERLAP_LINES: Lines of overlap between chunks
RAG_CHUNK_OVERLAP_LINES=2

# RAG_INCLUDE_COORDINATES: Include Excel coordinates in chunk metadata (True/False)
RAG_INCLUDE_COORDINATES=True

# RAG_INCLUDE_LOGIC_ANNOTATIONS: Include formula annotations in chunk text (True/False)
RAG_INCLUDE_LOGIC_ANNOTATIONS=True

